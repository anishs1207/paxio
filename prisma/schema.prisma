model ShortTermMemory {
  id             String   @id @default(cuid())
  userId         String
  conversationId String
  role           String
  content        String
  createdAt      DateTime @default(now())

  @@index([userId, conversationId])
}

model LongTermMemory {
  id        String   @id @default(cuid())
  userId    String
  category  String
  key       String
  value     String
  updatedAt DateTime @updatedAt

  @@unique([userId, key], name: "userId_key")
  @@index([userId])
}

model CreditTransaction {
  id           String   @id @default(uuid())
  userId       String
  type         String
  amount       Int
  balanceAfter Int
  requestId    String
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model newChat {
  id             String   @id @default(uuid())
  conversationId String
  userId         String
  role           String
  message        String
  payload        Json?
  creditsUsed    Int      @default(0)
  createdAt      DateTime @default(now())

  @@index([conversationId])
}

// Doomscroller research sessions
model DoomscrollSession {
  id        String   @id @default(uuid())
  userId    String
  prompt    String // Original user prompt
  topic     String // Extracted research topic
  platforms String[] // ["reddit", "linkedin", "x"]
  status    String   @default("RUNNING") // RUNNING | DONE | ERROR
  shareUrl  String? // Browser session public URL
  duration  String? // Time taken (e.g., "0h 5m 32s")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  results DoomscrollResult[]

  @@index([userId])
  @@index([status])
}

model DoomscrollResult {
  id        String            @id @default(uuid())
  sessionId String
  session   DoomscrollSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  platform  String // "reddit" | "linkedin" | "x"
  rawOutput String // Full findings text
  preview   String? // First 500 chars for quick display
  createdAt DateTime          @default(now())

  @@index([sessionId])
}

// Track failed Gemini API keys for 24h exclusion
model FailedApiKey {
  id        String   @id @default(cuid())
  keyHash   String   @unique // SHA-256 hash of the API key
  reason    String? // e.g. "429", "RESOURCE_EXHAUSTED"
  failedAt  DateTime @default(now())
  expiresAt DateTime // failedAt + 24 hours

  @@index([expiresAt])
}
