// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model WaitListUser {
  id        String   @id @default(uuid())
  name      String
  plan      PlanEnum @default(FREE)
  email     String
  createdAt DateTime @default(now())
}

enum PlanEnum {
  FREE
  PRO
}

model User {
  id        String   @id @default(uuid())
  name      String?
  email     String?  @unique
  password  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isOnboardingCompleted Boolean @default(false)
  onboardingName        String?
  onboardingCountry     String?
  onboardingSource      String?

  transactions CreditTransaction[]

  plan          PlanEnum  @default(FREE)
  planStartedAt DateTime?
  planExpiresAt DateTime?
  credits BigInt @default(0)

  gmailAccessToken  String?
  gmailRefreshToken String?
  gmailExpiry       BigInt?

  googleDocsAccessToken  String?
  googleDocsRefreshToken String?
  googleDocsExpiry       BigInt?

  googleSheetsAccessToken  String?
  googleSheetsRefreshToken String?
  googleSheetsExpiry       BigInt?

  googleCalendarAccessToken  String?
  googleCalendarRefreshToken String?
  googleCalendarExpiry       BigInt?

  googleDriveAccessToken  String?
  googleDriveRefreshToken String?
  googleDriveExpiry       BigInt?

  notionAccessToken String?

  quickDeliveryPhoneNuber     String?
  quickDeliveryAddress        String?
  quickDeliveryUpiId          String?
  quickDeliveryBlinkitCookies Json?
  quickDeliveryZeptoCookies   Json?

  autonomousTasks AutonomousTask[]
  zeptoSession   Json?
  blinkitSession Json?
  
  userEmailLists UserEmailList[]
}

model UserEmailList {
  id        String   @id @default(uuid())
  name      String
  email     String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model AutonomousTask {
  id                String    @id @default(uuid())
  userId            String
  prompt            String 
  description       String?
  workflow          Json
  triggerType       String 
  schedule          String? 
  scheduleType      String? 
  eventName         String? 
  pollInterval      String?
  status            String    @default("ACTIVE")
  active            Boolean   @default(true)
  lastRunAt         DateTime?
  lastPollAt        DateTime?
  lastResultSummary String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User                @relation(fields: [userId], references: [id])
  runs AutonomousTaskRun[]
}

model AutonomousTaskRun {
  id               String         @id @default(uuid())
  autonomousTask   AutonomousTask @relation(fields: [autonomousTaskId], references: [id])
  autonomousTaskId String
  runAt            DateTime       @default(now())
  success          Boolean
  summary          String
  rawResults       Json
}

model ShortTermMemory {
  id             String   @id @default(cuid())
  userId         String
  conversationId String
  role           String
  content        String
  createdAt      DateTime @default(now())

  @@index([userId, conversationId])
}

model LongTermMemory {
  id        String   @id @default(cuid())
  userId    String
  category  String
  key       String
  value     String
  updatedAt DateTime @updatedAt

  @@unique([userId, key], name: "userId_key")
  @@index([userId])
}

model CreditTransaction {
  id           String   @id @default(uuid())
  userId       String
  type         String
  amount       Int
  balanceAfter Int
  requestId    String
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model newChat {
  id             String   @id @default(uuid())
  conversationId String
  userId         String
  role           String
  message        String
  payload        Json?
  creditsUsed    Int      @default(0)
  createdAt      DateTime @default(now())

  @@index([conversationId])
}

model DoomscrollSession {
  id        String   @id @default(uuid())
  userId    String
  prompt    String 
  topic     String
  platforms String[]
  status    String   @default("RUNNING")
  shareUrl  String?
  duration  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  results DoomscrollResult[]

  @@index([userId])
  @@index([status])
}

model DoomscrollResult {
  id        String            @id @default(uuid())
  sessionId String
  session   DoomscrollSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  platform  String
  rawOutput String
  preview   String?
  createdAt DateTime          @default(now())

  @@index([sessionId])
}

model FailedApiKey {
  id        String   @id @default(cuid())
  keyHash   String   @unique
  reason    String?
  failedAt  DateTime @default(now())
  expiresAt DateTime

  @@index([expiresAt])
}
