generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model WaitListUser {
  id        String   @id @default(uuid())
  name      String
  plan      PlanEnum @default(FREE)
  email     String
  createdAt DateTime @default(now())
}

enum PlanEnum {
  FREE
  PRO
}

