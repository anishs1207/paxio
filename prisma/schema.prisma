model AutonomousTask {
  id                String    @id @default(uuid())
  userId            String
  prompt            String // 🆕 Original user prompt that created this workflow
  description       String? // 🆕 Optional short summary (for display)
  workflow          Json
  triggerType       String // "time" | "event"
  schedule          String? // cron expression for time triggers
  scheduleType      String? // "once" | "recurring"
  eventName         String? // for event triggers (e.g. "new_email")
  pollInterval      String? // e.g. "5m"
  status            String    @default("ACTIVE") // ACTIVE | PAUSED | DELETED
  active            Boolean   @default(true) // 🆕 For easy toggle in UI
  lastRunAt         DateTime?
  lastPollAt        DateTime?
  lastResultSummary String? // 🆕 Quick summary of the last run result
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User                @relation(fields: [userId], references: [id])
  runs AutonomousTaskRun[]
}

model AutonomousTaskRun {
  id               String         @id @default(uuid())
  autonomousTask   AutonomousTask @relation(fields: [autonomousTaskId], references: [id])
  autonomousTaskId String
  runAt            DateTime       @default(now())
  success          Boolean
  summary          String
  rawResults       Json // full run data (logs, summary, output, etc.)
}

